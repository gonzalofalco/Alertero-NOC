# ============================================
# ALERTERO CONFIGURATION EXAMPLE
# ============================================
# Copy to /etc/alertero/alertero.env and customize
# NEVER commit real secrets to git

# ============================================
# DATABASE
# ============================================
POSTGRES_DB=alertero
POSTGRES_USER=alertero
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ============================================
# WEBHOOK SECURITY
# ============================================
# Shared secret for Grafana webhook authentication
# Must match X-Webhook-Secret header from Grafana
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_TO_SECURE_WEBHOOK_SECRET

# ============================================
# APPLICATION
# ============================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================
# NETWORK (optional overrides)
# ============================================
# If you need to bind to specific IPs or ports
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443
