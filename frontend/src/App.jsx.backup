import { useState, useEffect } from 'react'
import { alertsApi } from './api'
import Filters from './components/Filters'
import AlertsTable from './components/AlertsTable'
import AlertDetail from './components/AlertDetail'

function App() {
  const [alerts, setAlerts] = useState([])
  const [stats, setStats] = useState(null)
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState(null)
  const [selectedAlert, setSelectedAlert] = useState(null)
  const [darkMode, setDarkMode] = useState(() => {
    const saved = localStorage.getItem('darkMode')
    return saved ? JSON.parse(saved) : false
  })
  const [filters, setFilters] = useState({
    status: '',
    severity: '',
    team: '',
    alertname: '',
    show_acked: true,
    show_silenced: false
  })

  useEffect(() => {
    localStorage.setItem('darkMode', JSON.stringify(darkMode))
    if (darkMode) {
      document.documentElement.classList.add('dark')
    } else {
      document.documentElement.classList.remove('dark')
    }
  }, [darkMode])

  useEffect(() => {
    fetchAlerts()
    fetchStats()
    const interval = setInterval(() => {
      fetchAlerts()
      fetchStats()
    }, 30000)
    return () => clearInterval(interval)
  }, [filters])

  const fetchAlerts = async () => {
    try {
      setLoading(true)
      const params = {}
      if (filters.status) params.status_filter = filters.status
      if (filters.severity) params.severity = filters.severity
      if (filters.team) params.team = filters.team
      if (filters.alertname) params.alertname = filters.alertname
      params.show_acked = filters.show_acked
      params.show_silenced = filters.show_silenced

      const response = await alertsApi.getCurrent(params)
      setAlerts(response.data.items || [])
      setError(null)
    } catch (err) {
      setError('Error cargando alertas: ' + err.message)
    } finally {
      setLoading(false)
    }
  }

  const fetchStats = async () => {
    try {
      const response = await alertsApi.getStats()
      setStats(response.data)
    } catch (err) {
      console.error('Error cargando stats:', err)
    }
  }

  const handleAcknowledge = async (alert, note) => {
    try {
      await alertsApi.acknowledge(alert.fingerprint, { 
        acked_by: 'usuario', 
        ack_note: note 
      })
      fetchAlerts()
      if (selectedAlert && selectedAlert.fingerprint === alert.fingerprint) {
        const updated = await alertsApi.getDetail(alert.fingerprint)
        setSelectedAlert(updated.data)
      }
    } catch (err) {
      alert('Error al reconocer alerta: ' + err.message)
    }
  }

  return (
    <div className={`min-h-screen transition-colors duration-300 ${
      darkMode 
        ? 'bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900' 
        : 'bg-gradient-to-br from-gray-50 to-blue-50'
    }`}>
      {/* Navbar mejorado con dark mode */}
      <nav className={`shadow-xl transition-colors duration-300 ${
        darkMode 
          ? 'bg-gradient-to-r from-gray-800 to-gray-900 border-b border-gray-700' 
          : 'bg-gradient-to-r from-blue-600 to-blue-700'
      }`}>
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="flex justify-between h-16">
            <div className="flex items-center">
              <div className="flex items-center space-x-3">
                <div className={`rounded-lg p-2 ${
                  darkMode ? 'bg-blue-500 bg-opacity-30' : 'bg-white bg-opacity-20'
                }`}>
                  <svg className="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
                  </svg>
                </div>
                <div>
                  <h1 className="text-2xl font-bold text-white">Alertero</h1>
                  <p className={`text-xs ${darkMode ? 'text-gray-300' : 'text-blue-100'}`}>
                    Grafana Alerts Dashboard
                  </p>
                </div>
              </div>
            </div>
            <div className="flex items-center space-x-3">
              {/* Toggle Dark Mode */}
              <button
                onClick={() => setDarkMode(!darkMode)}
                className={`p-2.5 rounded-lg transition-all duration-200 ${
                  darkMode 
                    ? 'bg-yellow-500 hover:bg-yellow-600 text-gray-900' 
                    : 'bg-white bg-opacity-20 hover:bg-opacity-30 text-white'
                } backdrop-blur-sm`}
                title={darkMode ? 'Modo Día' : 'Modo Noche'}
              >
                {darkMode ? (
                  <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fillRule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clipRule="evenodd"/>
                  </svg>
                ) : (
                  <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
                  </svg>
                )}
              </button>

              <button 
                onClick={() => { fetchAlerts(); fetchStats(); }}
                className={`px-4 py-2 rounded-lg transition-all duration-200 flex items-center space-x-2 backdrop-blur-sm ${
                  darkMode 
                    ? 'bg-blue-600 hover:bg-blue-700 text-white' 
                    : 'bg-white bg-opacity-20 text-white hover:bg-opacity-30'
                }`}
              >
                <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fillRule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clipRule="evenodd"/>
                </svg>
                <span className="text-sm font-medium">Refresh</span>
              </button>
            </div>
          </div>
        </div>
      </nav>

      {/* Stats Cards con dark mode */}
      {stats && (
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
          <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div className={`rounded-xl shadow-lg p-6 border-l-4 border-blue-500 hover:shadow-xl transition-all duration-200 ${
              darkMode 
                ? 'bg-gray-800 border-blue-400' 
                : 'bg-white'
            }`}>
              <div className="flex items-center justify-between">
                <div>
                  <div className={`text-sm font-medium uppercase tracking-wide ${
                    darkMode ? 'text-gray-400' : 'text-gray-500'
                  }`}>Total Alertas</div>
                  <div className={`text-3xl font-bold mt-2 ${
                    darkMode ? 'text-white' : 'text-gray-900'
                  }`}>{stats.total}</div>
                </div>
                <div className={`rounded-full p-3 ${
                  darkMode ? 'bg-blue-500 bg-opacity-30' : 'bg-blue-100'
                }`}>
                  <svg className={`w-8 h-8 ${
                    darkMode ? 'text-blue-400' : 'text-blue-600'
                  }`} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
                    <path fillRule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clipRule="evenodd"/>
                  </svg>
                </div>
              </div>
            </div>

            <div className={`rounded-xl shadow-lg p-6 border-l-4 hover:shadow-xl transition-all duration-200 ${
              darkMode 
                ? 'bg-gray-800 border-red-500' 
                : 'bg-gradient-to-br from-red-50 to-red-100 border-red-500'
            }`}>
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-sm font-medium text-red-400 uppercase tracking-wide">Critical</div>
                  <div className={`text-3xl font-bold mt-2 ${
                    darkMode ? 'text-red-400' : 'text-red-700'
                  }`}>{stats.critical}</div>
                </div>
                <div className={`rounded-full p-3 ${
                  darkMode ? 'bg-red-500 bg-opacity-30' : 'bg-red-200'
                }`}>
                  <svg className={`w-8 h-8 ${
                    darkMode ? 'text-red-400' : 'text-red-700'
                  }`} fill="currentColor" viewBox="0 0 20 20">
                    <path fillRule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clipRule="evenodd"/>
                  </svg>
                </div>
              </div>
            </div>

            <div className={`rounded-xl shadow-lg p-6 border-l-4 hover:shadow-xl transition-all duration-200 ${
              darkMode 
                ? 'bg-gray-800 border-yellow-500' 
                : 'bg-gradient-to-br from-yellow-50 to-yellow-100 border-yellow-500'
            }`}>
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-sm font-medium text-yellow-400 uppercase tracking-wide">Warning</div>
                  <div className={`text-3xl font-bold mt-2 ${
                    darkMode ? 'text-yellow-400' : 'text-yellow-700'
                  }`}>{stats.warning}</div>
                </div>
                <div className={`rounded-full p-3 ${
                  darkMode ? 'bg-yellow-500 bg-opacity-30' : 'bg-yellow-200'
                }`}>
                  <svg className={`w-8 h-8 ${
                    darkMode ? 'text-yellow-400' : 'text-yellow-700'
                  }`} fill="currentColor" viewBox="0 0 20 20">
                    <path fillRule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clipRule="evenodd"/>
                  </svg>
                </div>
              </div>
            </div>

            <div className={`rounded-xl shadow-lg p-6 border-l-4 hover:shadow-xl transition-all duration-200 ${
              darkMode 
                ? 'bg-gray-800 border-green-500' 
                : 'bg-gradient-to-br from-green-50 to-green-100 border-green-500'
            }`}>
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-sm font-medium text-green-400 uppercase tracking-wide">Resolved</div>
                  <div className={`text-3xl font-bold mt-2 ${
                    darkMode ? 'text-green-400' : 'text-green-700'
                  }`}>{stats.resolved}</div>
                </div>
                <div className={`rounded-full p-3 ${
                  darkMode ? 'bg-green-500 bg-opacity-30' : 'bg-green-200'
                }`}>
                  <svg className={`w-8 h-8 ${
                    darkMode ? 'text-green-400' : 'text-green-700'
                  }`} fill="currentColor" viewBox="0 0 20 20">
                    <path fillRule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clipRule="evenodd"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}

      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div className="lg:col-span-2 space-y-6">
            <Filters filters={filters} setFilters={setFilters} darkMode={darkMode} />
            
            {loading && (
              <div className={`text-center py-12 ${darkMode ? 'text-gray-300' : 'text-gray-600'}`}>
                <svg className="animate-spin h-12 w-12 mx-auto mb-4 text-blue-500" fill="none" viewBox="0 0 24 24">
                  <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4"></circle>
                  <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <p className="font-medium">Cargando alertas...</p>
              </div>
            )}
            {error && (
              <div className={`p-4 rounded-xl ${
                darkMode 
                  ? 'bg-red-900 bg-opacity-30 text-red-300 border border-red-700' 
                  : 'bg-red-100 text-red-700'
              }`}>{error}</div>
            )}
            {!loading && !error && (
              <AlertsTable 
                alerts={alerts}
                selectedAlert={selectedAlert}
                setSelectedAlert={setSelectedAlert}
                darkMode={darkMode}
              />
            )}
          </div>
          <div className="lg:col-span-1">
            {selectedAlert ? (
              <div className="lg:sticky lg:top-6">
                <AlertDetail
                  alert={selectedAlert}
                  setSelectedAlert={setSelectedAlert}
                  onAck={handleAcknowledge}
                  darkMode={darkMode}
                />
              </div>
            ) : (
              <div className={`rounded-xl shadow-lg p-8 text-center border transition-colors duration-300 ${
                darkMode 
                  ? 'bg-gray-800 border-gray-700' 
                  : 'bg-white border-gray-100'
              }`}>
                <svg className={`mx-auto h-12 w-12 ${
                  darkMode ? 'text-gray-600' : 'text-gray-400'
                }`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
                </svg>
                <p className={`mt-4 ${darkMode ? 'text-gray-400' : 'text-gray-500'}`}>
                  Selecciona una alerta para ver detalles
                </p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  )
}

export default App
